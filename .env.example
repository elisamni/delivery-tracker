APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./shipments.db
CHECK_INTERVAL_MINUTES=30
TRACKER_BATCH_SIZE=100

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Shipments
GOOGLE_SHEETS_CREDENTIALS_FILE=./google-service-account.json

TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_API_BASE=https://api.telegram.org

AGGREGATOR_PROVIDER=17track
AGGREGATOR_API_KEY=your-17track-api-key
AGGREGATOR_BASE_URL=https://api.17track.net/track/v2.2
AGGREGATOR_TIMEOUT_SECONDS=20

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000
PLAYWRIGHT_MAX_RETRIES=3
PLAYWRIGHT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36
PLAYWRIGHT_LOCALE=en-US

CYPRUS_POST_TRACKING_URL=https://www.cypruspost.post/en/track-n-trace-results
ACS_TRACKING_URL=https://www.acscourier.net/en/track-and-trace/
ACS_SEARCH_API_URL=https://api.acscourier.net/api/parcels/search
